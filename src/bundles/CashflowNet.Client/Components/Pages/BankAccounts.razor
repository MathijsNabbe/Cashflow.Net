@page "/bankaccounts"
@using CashflowNet.Client.Communication.ViewModels

<PageTitle>Bank accounts</PageTitle>

<MudIconButton Icon="@Icons.Material.Filled.AddCard" Color="Color.Primary" OnClick="CreateBankAccount"/>

<MudTable T="GetBankAccountsViewModel"
          ServerData="LoadBankAccounts"
          @ref="_bankAccountsTable">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Bank accounts</MudText>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>Name</MudTh>
        <MudTh>Iban</MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Name">@context.Name</MudTd>
        <MudTd DataLabel="Iban">@context.Iban</MudTd>
        <MudTd DataLabel="Actions">
            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                           Color="Color.Primary"
                           OnClick="@(() => DeleteBankAccount(context))"/>
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText>No bank accounts found</MudText>
    </NoRecordsContent>
</MudTable>